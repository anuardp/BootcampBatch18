@model ComicReader.DTOs.UserDto
@{
    ViewData["Title"] = "Profile";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow">
            <div class="card-header bg-info text-white">
                <h3><i class="fas fa-user-circle"></i> My Profile</h3>
            </div>
            <div class="card-body">
                <p><strong>Name:</strong> @Model.Name</p>
                <p><strong>Email:</strong> @Model.Email</p>
                <p><strong>Phone:</strong> @(Model.PhoneNumber ?? "-")</p>
                <p><strong>Role:</strong> @Model.Role</p>
                <p><strong>Subscription:</strong> 
                    @if (Model.IsSubscribed && Model.SubscribeEndDate > DateTime.UtcNow)
                    {
                        <span class="badge bg-success">Active until @Model.SubscribeEndDate?.ToString("yyyy-MM-dd")</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Free</span>
                    }
                </p>
                @if (!Model.IsSubscribed || Model.SubscribeEndDate <= DateTime.UtcNow)
                {
                    <a asp-action="Subscribe" class="btn btn-warning">Upgrade to Premium</a>
                }
            </div>
        </div>
    </div>
</div>